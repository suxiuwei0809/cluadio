# ===========================
# Claudio 个人 AI 电台 — 环境变量
# 复制此文件为 .env 并填入真实密钥后启动
# ===========================

# DeepSeek AI (必填)
DEEPSEEK_API_KEY=sk-xxxxxxxx

# Fish Audio TTS (必填)
FISH_AUDIO_KEY=xxxxxxxx

# 网易云音乐 ncm-cli (必填，需提前安装 ncm CLI 并登录)
# 安装：npx github:Davied-H/ncm-cli install --dir ~/.local/bin
# 登录：ncm login（打开浏览器扫码）
# 二进制路径（如已加入 PATH 可保持默认 'ncm'）：
NCM_BIN=ncm

# OpenWeather 天气 (可选，不填则跳过天气上下文)
OPENWEATHER_KEY=xxxxxxxx

# 飞书日程 (可选，不填则跳过日程上下文)
FEISHU_APP_ID=xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxx
